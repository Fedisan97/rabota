<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="rabota.RegisterWindow"
        Title="Регистрация"
        Width="450"
        Height="430"
        CanResize="False"
        WindowStartupLocation="CenterOwner">
    
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto"
          ColumnDefinitions="*,*"
          Margin="20">
        
        <TextBlock Grid.Row="0" Grid.ColumnSpan="2" 
                   Text="Регистрация нового пользователя"
                   FontSize="20"
                   FontWeight="Bold"
                   Foreground="#2C3E50"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>
        
        <TextBlock Grid.Row="1" Grid.Column="0" Text="ФИО:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FullNameBox" Margin="5"/>
        
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Логин:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" x:Name="UsernameBox" Margin="5"/>
        
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Пароль:" VerticalAlignment="Center"/>
        <TextBox Grid.Row="3" Grid.Column="1" x:Name="PasswordBox" Margin="5" PasswordChar="*"/>
        
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Роль:" VerticalAlignment="Center"/>
        <ComboBox Grid.Row="4" Grid.Column="1" x:Name="RoleCombo" Margin="5" Width="150" HorizontalAlignment="Left">
            <ComboBoxItem Content="Кассир" IsSelected="True"/>
            <ComboBoxItem Content="Администратор"/>
        </ComboBox>
        
        <TextBlock Grid.Row="5" Grid.ColumnSpan="2"
                   x:Name="ErrorText"
                   Foreground="#E74C3C"
                   TextWrapping="Wrap"
                   Margin="0,10,0,0"
                   HorizontalAlignment="Center"/>
        
        <StackPanel Grid.Row="6" Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,20,0,0"
                    Spacing="20">
            <Button x:Name="RegisterButton" 
                    Content="Зарегистрировать" 
                    Width="150"
                    Background="#0078D7"
                    Foreground="White"/>
            <Button x:Name="CancelButton" Content="Отмена" Width="100"/>
        </StackPanel>
        
    </Grid>
</Window>