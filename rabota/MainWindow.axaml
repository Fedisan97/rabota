<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:rabota.ViewModels"
        x:Class="rabota.MainWindow"
        Title="Кинотеатр - Афиша"
        Width="1200"
        Height="600"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="FontFamily" Value="Arial"/>
        </Style>
        <Style Selector="TextBlock.h1">
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="FontFamily" Value="Georgia"/>
        </Style>
        <Style Selector="Button">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#D4AF37"/>
            <Setter Property="BorderBrush" Value="#8B0000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
        </Style>
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#8B0000"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
        </Style>
        <Style Selector="ListBoxItem">
            <Setter Property="Background" Value="#1A1A1A"/>
            <Setter Property="Foreground" Value="#E0E0E0"/>
        </Style>
        <Style Selector="ListBoxItem:selected">
            <Setter Property="Background" Value="#8B0000"/>
            <Setter Property="Foreground" Value="#D4AF37"/>
        </Style>
    </Window.Styles>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#1A1A1A" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                <TextBox x:Name="SearchBox" Width="200" Foreground="Black"/>
                <ComboBox x:Name="GenreFilter" Width="150"/>
                <DatePicker x:Name="DateFilter" Width="150"/>
                <Button x:Name="ClearDateBtn" Content="Сбросить дату" Width="100"/>
                <ComboBox x:Name="SortCombo" Width="150" SelectedIndex="0">
                    <ComboBoxItem Content="По времени (по умолчанию)"/>
                    <ComboBoxItem Content="По цене"/>
                    <ComboBoxItem Content="По времени"/>
                </ComboBox>
                <Button x:Name="ApplyFiltersBtn" Content="Применить" Background="#8B0000"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="SessionsList" Margin="10">
            <ListBox.ItemTemplate>
                <DataTemplate DataType="vm:SessionViewModel">
                    <Border Background="#2A2A2A" Margin="5" Padding="10" CornerRadius="5">
                        <Grid ColumnDefinitions="*,Auto,Auto">
                            <StackPanel>
                                <TextBlock Text="{Binding FilmTitle}" FontSize="18" FontWeight="Bold" Foreground="#D4AF37"/>
                                <TextBlock Text="{Binding Genre}" Foreground="#CCCCCC"/>
                                <TextBlock Text="{Binding FormattedTime}" Foreground="#FFD700"/>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="Зал: " Foreground="#CCCCCC"/>
                                    <TextBlock Text="{Binding HallName}" Foreground="#CCCCCC"/>
                                </StackPanel>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding DurationStr}" VerticalAlignment="Center" Margin="20,0" Foreground="#CCCCCC"/>
                            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                <TextBlock Text="{Binding Price} ₽" FontSize="16" FontWeight="Bold" Foreground="#D4AF37"/>
                                <Button Content="Купить билет" Tag="{Binding SessionId}" Click="OnBuyTicketClick" Background="#8B0000"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Border DockPanel.Dock="Bottom" Background="#1A1A1A" Padding="5">
            <TextBlock x:Name="StatusText" Foreground="#D4AF37" FontSize="12"/>
        </Border>
    </DockPanel>
</Window>